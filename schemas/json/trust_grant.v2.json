{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.iscp.dev/json/trust_grant.v2.json",
  "title": "ISCP Trust Grant v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "grant_id", "issuer", "subject_device_id", "audience", "confirmation_thumbprint", "permissions", "not_before", "expires_at", "revocation_epoch", "signature"],
  "properties": {
    "type": { "const": "iscp.trust_grant.v2" },
    "grant_id": { "type": "string", "minLength": 1 },
    "issuer": { "type": "string", "minLength": 1 },
    "subject_device_id": { "type": "string", "minLength": 1 },
    "audience": { "type": "string", "minLength": 1 },
    "confirmation_thumbprint": { "type": "string", "minLength": 8 },
    "permissions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "relay_constraints": { "type": "array", "items": { "type": "string" } },
    "not_before": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "revocation_epoch": { "type": "integer", "minimum": 0 },
    "signature": { "$ref": "#/$defs/signature" }
  },
  "$defs": {
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alg", "kid", "value"],
      "properties": {
        "alg": { "const": "Ed25519" },
        "kid": { "type": "string" },
        "value": { "type": "string", "contentEncoding": "base64url" }
      }
    }
  }
}

